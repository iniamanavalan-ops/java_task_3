import java.util.ArrayList;
import java.util.Scanner;

class EmailList {
    private ArrayList<String> emails;

    public EmailList() {
        emails = new ArrayList<>();
    }

    public void addEmail(String email) {
        emails.add(email);
        System.out.println("Email added successfully!");
    }

    public void removeEmail(String email) {
        if (emails.remove(email)) {
            System.out.println("Email removed successfully!");
        } else {
            System.out.println("Email not found!");
        }
    }

    public void listEmails() {
        if (emails.isEmpty()) {
            System.out.println("Email list is empty.");
        } else {
            System.out.println("Email List:");
            for (int i = 0; i < emails.size(); i++) {
                System.out.println((i + 1) + ". " + emails.get(i));
            }
        }
    }

    public void checkEmail(String email) {
        if (emails.contains(email)) {
            System.out.println(email + " is in the list.");
        } else {
            System.out.println(email + " is not in the list.");
        }
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        EmailList emailList = new EmailList();

        int choice;

        do {
            System.out.println("\n1. Add Email");
            System.out.println("2. Remove Email");
            System.out.println("3. List Emails");
            System.out.println("4. Check Email");
            System.out.println("5. Quit");

            System.out.print("\nEnter your choice: ");
            choice = sc.nextInt();
            sc.nextLine(); // Consume newline

            switch (choice) {
                case 1:
                    System.out.print("Enter email address to add: ");
                    String addEmail = sc.nextLine();
                    emailList.addEmail(addEmail);
                    break;

                case 2:
                    System.out.print("Enter email address to remove: ");
                    String removeEmail = sc.nextLine();
                    emailList.removeEmail(removeEmail);
                    break;

                case 3:
                    emailList.listEmails();
                    break;

                case 4:
                    System.out.print("Enter email address to check: ");
                    String checkEmail = sc.nextLine();
                    emailList.checkEmail(checkEmail);
                    break;

                case 5:
                    System.out.println("Exiting program...");
                    break;

                default:
                    System.out.println("Invalid choice! Please try again.");
            }

        } while (choice != 5);

        sc.close();
    }
}






