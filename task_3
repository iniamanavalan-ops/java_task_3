import java.util.*;

class Book {
    String title, author, isbn;
    int year;

    Book(String t, String a, String i, int y) {
        title = t;
        author = a;
        isbn = i;
        year = y;
    }

    public String toString() {
        return "\"" + title + "\" by " + author;
    }
}

class LibraryCatalog {
    ArrayList<Book> books = new ArrayList<>();

    void addBook(Book b) {
        books.add(b);
        System.out.println("Book added successfully!");
    }
 
    void removeBook(String title) {
        books.removeIf(b -> b.title.equalsIgnoreCase(title));
        System.out.println("Book removed successfully!");
    }

    void listBooks() {
        System.out.println("Book List:");
        for (int i = 0; i < books.size(); i++)
            System.out.println((i + 1) + ". " + books.get(i));
    }

    void searchByTitle(String title) {
        System.out.println("Found books:");
        for (Book b : books)
            if (b.title.equalsIgnoreCase(title))
                System.out.println(b);
    }

    void searchByAuthor(String author) {
        System.out.println("Found books:");
        for (Book b : books)
            if (b.author.equalsIgnoreCase(author))
                System.out.println(b);
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        LibraryCatalog lib = new LibraryCatalog();
        int ch;

        do {
            System.out.println("\n1.Add Book\n2.Remove Book\n3.List Books");
            System.out.println("4.Search by Title\n5.Search by Author\n6.Quit");
            System.out.print("Enter choice: ");
            ch = sc.nextInt();
            sc.nextLine();

            switch (ch) {
                case 1:
                    System.out.print("Enter title: ");
                    String t = sc.nextLine();

                    System.out.print("Enter author: ");
                    String a = sc.nextLine();

                    System.out.print("Enter ISBN: ");
                    String i = sc.nextLine();

                    System.out.print("Enter year: ");
                    int y = sc.nextInt();
                    sc.nextLine();

                    lib.addBook(new Book(t, a, i, y));
                    break;

                case 2:
                    System.out.print("Enter title to remove: ");
                    lib.removeBook(sc.nextLine());
                    break;

                case 3:
                    lib.listBooks();
                    break;

                case 4:
                    System.out.print("Enter title to search: ");
                    lib.searchByTitle(sc.nextLine());
                    break;

                case 5:
                    System.out.print("Enter author to search: ");
                    lib.searchByAuthor(sc.nextLine());
                    break;

                case 6:
                    System.out.println("Program Ended");
            }
        } while (ch != 6);

        sc.close();
    }
}


